{
  "name": "coworker-bot",
  "version": "0.1.0",
  "description": "Discord bot that drifts into voice channels and mutters lines from The Coworker (Abiotic Factor).",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "register-commands": "tsx src/scripts/register-commands.ts",
    "setup-whisper": "bash scripts/setup-whisper.sh",
    "deploy:fly": "fly deploy --remote-only",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.19.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/schedule": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.13",
    "prism-media": "^1.3.5",
    "reflect-metadata": "^0.2.0",
    "rotating-file-stream": "^3.2.9",
    "rxjs": "^7.8.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
