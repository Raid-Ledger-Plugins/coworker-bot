# Discord bot credentials (create a new bot at https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Comma-separated list of guild (server) IDs where the bot is allowed to operate.
# Leave empty to allow all guilds the bot is in.
ALLOWED_GUILD_IDS=

# Scheduler tuning
# How often the scheduler ticks (ms)
TICK_INTERVAL_MS=120000
# Probability of attempting a visit on any given tick (0.0 - 1.0)
VISIT_PROBABILITY=0.03
# Minimum humans in a voice channel before bot considers visiting
MIN_OCCUPANTS=2
# Global cooldown across all channels (minutes)
GLOBAL_COOLDOWN_MIN=90
# Per-channel cooldown (minutes)
CHANNEL_COOLDOWN_MIN=360

# Visit choreography
# How many clips to play per visit (randomized in [MIN, MAX])
CLIPS_PER_VISIT_MIN=1
CLIPS_PER_VISIT_MAX=3
# Pause between clips (ms)
PAUSE_BETWEEN_CLIPS_MS=4000
# How long the bot lingers after the last clip (ms)
LINGER_AFTER_MS=15000

# Quiet hours (24h local time, bot will not visit between these)
# Set both to the same value to disable quiet hours.
QUIET_HOURS_START=03
QUIET_HOURS_END=10

# Voice listening (contextual response)
# When true, the bot records a short sample after joining, transcribes it with
# whisper.cpp, and matches keywords to pick an appropriate clip category. When
# false, every visit just plays a random clip.
LISTEN_ENABLED=true
# How long to record audio for transcription (ms)
LISTEN_DURATION_MS=7000
# Probability that the keyword-tree match is overridden with a random clip
# (0.0 - 1.0). Keeps the bot from feeling robotic when it matches the same
# keyword repeatedly.
RANDOM_CLIP_PROBABILITY=0.3
# whisper.cpp binary (install via: brew install whisper-cpp)
WHISPER_BIN_PATH=whisper-cli
# whisper.cpp model file (download via: npm run setup-whisper)
WHISPER_MODEL_PATH=./models/ggml-tiny.en.bin

# Paths
CLIPS_DIR=./clips
DATA_DIR=./data
