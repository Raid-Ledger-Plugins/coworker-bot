# Discord bot credentials (create a new bot at https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Comma-separated list of guild (server) IDs where the bot is allowed to operate.
# Leave empty to allow all guilds the bot is in.
ALLOWED_GUILD_IDS=

# Scheduler tuning
# How often the scheduler ticks (ms)
TICK_INTERVAL_MS=120000
# Probability of attempting a visit on any given tick (0.0 - 1.0)
VISIT_PROBABILITY=0.03
# Minimum humans in a voice channel before bot considers visiting
MIN_OCCUPANTS=2
# Global cooldown across all channels (minutes)
GLOBAL_COOLDOWN_MIN=90
# Per-channel cooldown (minutes)
CHANNEL_COOLDOWN_MIN=360

# Visit choreography
# How many clips to play per visit (randomized in [MIN, MAX])
CLIPS_PER_VISIT_MIN=1
CLIPS_PER_VISIT_MAX=3
# Pause between clips (ms)
PAUSE_BETWEEN_CLIPS_MS=4000
# How long the bot lingers after the last clip (ms)
LINGER_AFTER_MS=15000

# Quiet hours (24h local time, bot will not visit between these)
# Set both to the same value to disable quiet hours.
QUIET_HOURS_START=03
QUIET_HOURS_END=10

# Voice listening (contextual response)
# When true, the bot records a short sample after joining, transcribes it with
# whisper.cpp, and matches keywords to pick an appropriate clip category. When
# false, every visit just plays a random clip.
LISTEN_ENABLED=true
# How long to record audio for transcription (ms)
LISTEN_DURATION_MS=7000
# Probability that the keyword-tree match is overridden with a random clip
# (0.0 - 1.0). Keeps the bot from feeling robotic when it matches the same
# keyword repeatedly.
RANDOM_CLIP_PROBABILITY=0.3

# Text-channel chatter (contextual response in text channels)
# The bot occasionally reads the last few messages in an active text channel,
# matches the same keyword tree, and posts a themed text line. Much rarer than
# voice visits — the defaults cap it at roughly once a week.
# NOTE: reading message content requires the *Message Content Intent*, a
# privileged intent you must toggle ON in the Discord developer portal
# (Bot tab → Privileged Gateway Intents → Message Content Intent).
TEXT_ENABLED=true
# Probability of attempting a text post on any given tick (0.0 - 1.0).
# The weekly cooldown below is the real cap; this just adds jitter.
TEXT_POST_PROBABILITY=0.05
# Global cooldown across all text channels (minutes). 10080 = 7 days.
TEXT_GLOBAL_COOLDOWN_MIN=10080
# Per-channel cooldown for text posts (minutes). 10080 = 7 days.
TEXT_CHANNEL_COOLDOWN_MIN=10080
# The bot only posts into channels with live chatter. A channel counts as
# active only when, within the last TEXT_ACTIVITY_WINDOW_MIN minutes, it has
# seen at least TEXT_MIN_MESSAGES human messages from at least TEXT_MIN_AUTHORS
# distinct people. Raise these to require busier conversations; lower them to
# let the bot chime into quieter channels.
TEXT_ACTIVITY_WINDOW_MIN=60
TEXT_MIN_MESSAGES=4
TEXT_MIN_AUTHORS=2
# How many recent messages to read for keyword context.
TEXT_CONTEXT_MESSAGES=20
# Probability the keyword-tree match is overridden with a random line (0.0 - 1.0).
RANDOM_LINE_PROBABILITY=0.3

# whisper.cpp binary (install via: brew install whisper-cpp)
WHISPER_BIN_PATH=whisper-cli
# whisper.cpp model file (download via: npm run setup-whisper)
WHISPER_MODEL_PATH=./models/ggml-tiny.en.bin

# Logging
# Stdout level: error | warn | info | debug | verbose
LOG_LEVEL=info
# When set, the bot also tees a filtered, daily-rotated copy of its logs to
# <LOG_DIR>/coworker.log (WARN+ from anywhere, plus the bot's own info/debug;
# framework boot chatter is dropped). Leave empty for stdout-only local runs.
# In production (e.g. Fly) point this at the persistent volume so history
# survives restarts — see fly.toml.
LOG_DIR=
# How many days of rotated log files to keep.
LOG_KEEP_DAYS=60

# Health endpoint
# When > 0, serve GET /health on 0.0.0.0:<HEALTH_PORT> returning 200 once the
# Discord gateway is ready, 503 otherwise. Used by Fly's machine health check.
# Leave 0 to disable (local dev / docker-compose don't need it).
HEALTH_PORT=0

# Paths
CLIPS_DIR=./clips
LINES_DIR=./lines
DATA_DIR=./data
